{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  // GitHub App commits via the Contents API; avoids gitAuthor mismatch with the App bot.
  platformCommit: 'enabled',
  timezone: 'UTC',
  // PR cadence is enforced by .github/workflows/renovate.yaml (Sun/Wed/Sat). A
  // weekend-only schedule here prevented those mid-week runs from opening updates.
  labels: [
    'dependencies',
  ],
  prConcurrentLimit: 10,
  prHourlyLimit: 0,
  // Run `go mod tidy` natively as part of every gomod artifact update. This is the
  // reliable equivalent of the CI codegen `go mod tidy` check -- unlike a shell
  // postUpgradeTask it needs no allowedCommands entry and uses the go.mod toolchain,
  // so go.sum is always tidy in the PR (no chicken-and-egg with the allowlist).
  postUpdateOptions: [
    'gomodTidy',
  ],
  // The hashed lockfile is generated from docs/requirements.txt via a post-upgrade
  // task; Renovate must never try to edit it directly.
  ignorePaths: [
    'docs/requirements-hashed.txt',
  ],
  // Custom datasource for envtest Kubernetes assets. setup-envtest discovers binaries
  // from this exact index (its --index default), so reading the same file guarantees
  // Renovate only proposes ENVTEST_K8S_VERSION values that actually have binaries.
  // The YAML shape is { releases: { "v1.36.0": {...}, ... } }; we map the keys to
  // the { releases: [ { version } ] } structure Renovate expects.
  customDatasources: {
    'envtest-k8s': {
      defaultRegistryUrlTemplate: 'https://raw.githubusercontent.com/kubernetes-sigs/controller-tools/HEAD/envtest-releases.yaml',
      format: 'yaml',
      transformTemplates: [
        '{ "releases": $map($keys(releases), function($v) { { "version": $v } }) }',
      ],
    },
  },
  packageRules: [
    // ----------------------------------------------------------------------
    // Ownership split with Dependabot
    // ----------------------------------------------------------------------
    {
      description: 'Let Dependabot own GitHub Action SHAs (avoid duplicate PRs)',
      matchManagers: [
        'github-actions',
      ],
      enabled: false,
    },
    {
      description: 'UI npm dependencies are updated manually / via npm audit fix, not Renovate',
      matchManagers: [
        'npm',
      ],
      enabled: false,
    },
    {
      description: 'Dependabot owns general Go module updates',
      matchManagers: [
        'gomod',
      ],
      matchDepTypes: [
        'require',
        'indirect',
      ],
      enabled: false,
    },
    // ----------------------------------------------------------------------
    // Group A: Kubernetes platform (gomod + Makefile + e2e workflow, lockstep)
    // controller-runtime <-> multicluster-runtime <-> k8s.io/* <-> setup-envtest
    // ----------------------------------------------------------------------
    {
      description: 'Renovate owns the coupled Kubernetes platform gomod deps so they bump in lockstep',
      matchManagers: [
        'gomod',
      ],
      matchPackageNames: [
        'k8s.io/**',
        'sigs.k8s.io/controller-runtime',
        'sigs.k8s.io/multicluster-runtime',
        'sigs.k8s.io/structured-merge-diff/**',
        'sigs.k8s.io/json',
        'sigs.k8s.io/randfill',
      ],
      enabled: true,
      groupName: 'Kubernetes platform',
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
    },
    {
      description: 'Group the envtest Makefile/e2e versions into the Kubernetes platform bump',
      matchManagers: [
        'custom.regex',
      ],
      matchDepNames: [
        'setup-envtest',
        'envtest-k8s',
      ],
      groupName: 'Kubernetes platform',
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
    },
    // ----------------------------------------------------------------------
    // Group B: Go toolchain + golangci-lint (+ golang base image)
    // ----------------------------------------------------------------------
    {
      description: 'Group Go, the golang base image, and golangci-lint together',
      matchManagers: [
        'gomod',
        'custom.regex',
        'dockerfile',
      ],
      matchPackageNames: [
        'go',
        'golang',
        'golangci-lint',
        'golangci/golangci-lint',
      ],
      groupName: 'Go and linter tooling',
      commitMessageTopic: 'Go and linter tooling',
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
      postUpgradeTasks: {
        commands: [
          'make lint-fix || true',
        ],
        fileFilters: [
          '**/*.go',
          'go.mod',
          'go.sum',
        ],
        executionMode: 'branch',
      },
    },
    // ----------------------------------------------------------------------
    // Group C: goreleaser (Makefile + both release workflows in one PR)
    // ----------------------------------------------------------------------
    {
      description: 'Keep goreleaser in sync across the Makefile and release workflows',
      matchDepNames: [
        'goreleaser/goreleaser',
      ],
      groupName: 'goreleaser',
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
    },
    // ----------------------------------------------------------------------
    // Other Makefile tools with their required post-ops
    // ----------------------------------------------------------------------
    {
      description: 'mockery: stay on v2 (v3 is a breaking rewrite) and always regenerate mocks',
      matchDepNames: [
        'vektra/mockery',
      ],
      allowedVersions: '<3.0.0',
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
      postUpgradeTasks: {
        commands: [
          'make mockery-gen',
        ],
        fileFilters: [
          '**/mocks/**',
          '**/*.go',
        ],
        executionMode: 'branch',
      },
    },
    {
      description: 'kustomize: regenerate the consolidated installer after a bump',
      matchDepNames: [
        'kubernetes-sigs/kustomize',
      ],
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
      postUpgradeTasks: {
        commands: [
          'make build-installer || true',
        ],
        fileFilters: [
          'dist/**',
        ],
        executionMode: 'branch',
      },
    },
    {
      description: 'controller-tools: regenerate manifests and deepcopy code after a bump',
      matchDepNames: [
        'kubernetes-sigs/controller-tools',
      ],
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
      postUpgradeTasks: {
        commands: [
          'go mod tidy',
          'make manifests generate || true',
        ],
        fileFilters: [
          'config/**',
          'test/**',
          '**/*.go',
          'go.mod',
          'go.sum',
        ],
        executionMode: 'branch',
      },
    },
    {
      description: 'kube-rbac-proxy image is baked into config + dist/install.yaml; regenerate them on bump',
      matchDepNames: [
        'quay.io/brancz/kube-rbac-proxy',
      ],
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
      postUpgradeTasks: {
        commands: [
          'make manifests || true',
          'make build-installer || true',
        ],
        fileFilters: [
          'config/**',
          'test/**',
          'dist/**',
        ],
        executionMode: 'branch',
      },
    },
    {
      // NOTE: kubebuilder must stay in sync with the external gitops-promoter-helm
      // repo (see the comment in kubebuilder_helm.yaml); review/coordinate manually.
      description: 'kubebuilder version must match the external gitops-promoter-helm repo; review manually',
      matchDepNames: [
        'kubernetes-sigs/kubebuilder',
      ],
      groupName: 'kubebuilder',
      addLabels: [
        'coordinate-with-helm-repo',
      ],
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'deps',
      automerge: false,
    },
    // ----------------------------------------------------------------------
    // Docker base images: full version tags only, never digest-only PRs
    // ----------------------------------------------------------------------
    {
      description: 'No digest-only image bumps; only bump on a real new version tag',
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
        'pinDigest',
      ],
      enabled: false,
    },
    {
      description: 'The golang base image rides with the Go toolchain group',
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'golang',
      ],
      groupName: 'Go and linter tooling',
      automerge: false,
    },
    // ----------------------------------------------------------------------
    // Docs (MkDocs / pip): group and regenerate the hashed lockfile
    // ----------------------------------------------------------------------
    {
      description: 'Group MkDocs/pip docs dependencies and regenerate the hashed lockfile',
      matchManagers: [
        'pip_requirements',
      ],
      groupName: 'docs dependencies',
      semanticCommits: 'enabled',
      semanticCommitType: 'chore',
      semanticCommitScope: 'docs',
      automerge: false,
      postUpgradeTasks: {
        commands: [
          'pip install pip-tools',
          'pip-compile --generate-hashes -o docs/requirements-hashed.txt docs/requirements.txt',
        ],
        fileFilters: [
          'docs/requirements-hashed.txt',
        ],
        executionMode: 'branch',
      },
    },
  ],
  customManagers: [
    // ===== Go toolchain version (go.mod + workflows) =====
    {
      customType: 'regex',
      description: 'Update Go version in go.mod',
      managerFilePatterns: [
        '/^go\\.mod$/',
      ],
      matchStrings: [
        'go (?<currentValue>\\d+\\.\\d+(\\.\\d+)?)',
      ],
      depNameTemplate: 'go',
      datasourceTemplate: 'golang-version',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      description: 'Update Go version in GitHub Actions workflows',
      managerFilePatterns: [
        '/^\\.github/workflows/.*\\.ya?ml$/',
      ],
      matchStrings: [
        'go-version:\\s*[\'"]?(?<currentValue>\\d+\\.\\d+(\\.\\d+)?)[\'"]?',
      ],
      depNameTemplate: 'go',
      datasourceTemplate: 'golang-version',
      versioningTemplate: 'semver',
    },
    // ===== golangci-lint (Makefile + workflows, incl. SHA-pinned action) =====
    {
      customType: 'regex',
      description: 'Update golangci-lint version in Makefile',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'GOLANGCI_LINT_VERSION\\s*\\??=\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'golangci-lint',
      packageNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update golangci-lint version in GitHub Actions (handles SHA-pinned action)',
      managerFilePatterns: [
        '/^\\.github/workflows/.*\\.ya?ml$/',
      ],
      matchStrings: [
        'golangci/golangci-lint-action@(?:[0-9a-f]{7,40}|v\\d+)[\\s\\S]*?version:\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'golangci-lint',
      packageNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    // ===== kube-rbac-proxy (runtime sidecar image) =====
    {
      customType: 'regex',
      description: 'Update kube-rbac-proxy image version',
      managerFilePatterns: [
        '/^config/default/manager_auth_proxy_patch\\.yaml$/',
      ],
      matchStrings: [
        'image:\\s*quay\\.io/brancz/kube-rbac-proxy:(?<currentValue>v\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'quay.io/brancz/kube-rbac-proxy',
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
    },
    // ===== Kubernetes platform: envtest tooling + assets + e2e matrix =====
    {
      customType: 'regex',
      description: 'Update setup-envtest release branch to track the controller-runtime minor',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'ENVTEST_VERSION\\s*\\??=\\s*release-(?<currentValue>\\d+\\.\\d+)',
      ],
      depNameTemplate: 'setup-envtest',
      packageNameTemplate: 'kubernetes-sigs/controller-runtime',
      datasourceTemplate: 'github-tags',
      versioningTemplate: 'loose',
      extractVersionTemplate: '^v(?<version>\\d+\\.\\d+)',
    },
    {
      customType: 'regex',
      // Track ENVTEST_K8S_VERSION against the SAME index setup-envtest reads
      // (custom datasource 'envtest-k8s' -> controller-tools envtest-releases.yaml),
      // so Renovate only ever proposes a k8s version that has published envtest
      // binaries. Using kubernetes/kubernetes tags here previously proposed 1.36.1,
      // which envtest never built, breaking tests with `exec: "etcd": ... not found`.
      description: 'Update envtest Kubernetes assets version (only versions with published envtest binaries)',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'ENVTEST_K8S_VERSION\\s*\\??=\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'envtest-k8s',
      datasourceTemplate: 'custom.envtest-k8s',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    // ===== Makefile tool versions =====
    {
      customType: 'regex',
      description: 'Update kustomize version in Makefile',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'KUSTOMIZE_VERSION\\s*\\??=\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'kubernetes-sigs/kustomize',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^kustomize/v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update controller-tools version in Makefile',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'CONTROLLER_TOOLS_VERSION\\s*\\??=\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'kubernetes-sigs/controller-tools',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update mockery version in Makefile',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'MOCKERY_VERSION\\s*\\??=\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'vektra/mockery',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update deadcode (golang.org/x/tools) version in Makefile',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'DEADCODE_VERSION\\s*\\??=\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'golang.org/x/tools',
      datasourceTemplate: 'go',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      description: 'Update goreleaser version in Makefile',
      managerFilePatterns: [
        '/^Makefile$/',
      ],
      matchStrings: [
        'GORELEASER_VERSION\\s*\\??=\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'goreleaser/goreleaser',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    // ===== goreleaser pinned in release workflows (kept in lockstep) =====
    {
      customType: 'regex',
      description: 'Update goreleaser version pinned in release workflows',
      managerFilePatterns: [
        '/^\\.github/workflows/release\\.yaml$/',
        '/^\\.github/workflows/release-latest\\.yaml$/',
      ],
      matchStrings: [
        'goreleaser/goreleaser-action@[\\s\\S]*?version:\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'goreleaser/goreleaser',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    // ===== Workflow tool inputs (version: fields Dependabot cannot reach) =====
    {
      customType: 'regex',
      description: 'Update Tilt version in the tilt-ci workflow',
      managerFilePatterns: [
        '/^\\.github/workflows/tilt-ci\\.yaml$/',
      ],
      matchStrings: [
        'TILT_VERSION=v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'tilt-dev/tilt',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update kind version in helm/kind-action inputs',
      managerFilePatterns: [
        '/^\\.github/workflows/.*\\.ya?ml$/',
      ],
      matchStrings: [
        'helm/kind-action@[\\s\\S]*?\\n\\s*version:\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'kubernetes-sigs/kind',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update helm version in the azure/setup-helm input',
      managerFilePatterns: [
        '/^\\.github/workflows/.*\\.ya?ml$/',
      ],
      matchStrings: [
        'azure/setup-helm@[\\s\\S]*?version:\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'helm/helm',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update kubebuilder version in the kubebuilder_helm workflow',
      managerFilePatterns: [
        '/^\\.github/workflows/kubebuilder_helm\\.yaml$/',
      ],
      matchStrings: [
        'KUBEBUILDER_VERSION:\\s*v(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'kubernetes-sigs/kubebuilder',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Update docker engine version pinned in release workflows',
      managerFilePatterns: [
        '/^\\.github/workflows/release\\.yaml$/',
        '/^\\.github/workflows/release-latest\\.yaml$/',
      ],
      matchStrings: [
        'docker/setup-docker-action@[\\s\\S]*?tag=(?<currentValue>\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'moby/moby',
      datasourceTemplate: 'github-tags',
      versioningTemplate: 'semver',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
  ],
}
